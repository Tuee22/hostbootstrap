-- Shared warm-store build configuration, imported by all three project files
-- (cabal.project builds the full shared store; core.project and daemon.project
-- are the layered freeze projections — see documents/engineering/warm_store.md).
--
-- The warm-store contract requires the store keys here to match downstream
-- project builds. tests/benchmarks/shared expand the set of pre-built
-- configurations so derived projects that use --enable-tests
-- --enable-benchmarks --enable-shared get cache hits. -O2 standardises the
-- optimisation level; downstream projects that compile at -O2 reuse the
-- pre-built unfoldings exposed at this opt level. All three project files share
-- one builddir so the layered freezes are projected from one shared store.
with-compiler: ghc-9.12.4
builddir: /opt/build/haskell/basecontainer-deps/dist-newstyle

tests: True
benchmarks: True
shared: True

optimization: 2
